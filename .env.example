# ==============================================================================
# STERKTE RECORDS DISTRIBUTOR — Variables d'environnement
# ==============================================================================
# Copie ce fichier en `.env.local` (jamais committé) et renseigne les valeurs
# réelles au fur et à mesure que les comptes tiers sont créés.
# `.env.local` est prioritaire sur `.env` et ignoré par git (voir .gitignore).
#
# Rien ici n'est requis pour lancer `pnpm dev` au Sprint 0 : src/lib/env.ts
# ne bloque que sur les variables du socle applicatif. Chaque intégration
# (Supabase, Stripe, LabelGrid...) vérifie sa propre config au moment de
# l'utiliser, une fois le Sprint correspondant démarré.
# ==============================================================================

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
NODE_ENV=development
# URL publique du site (utilisée pour les emails, metadata, webhooks de retour).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# Supabase — Postgres + Auth + RLS + Realtime (§6.1, §12, §17)
# Créer un projet sur https://supabase.com puis Project Settings > API.
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé service_role : NE JAMAIS exposer côté client, ni committer. Utilisée
# uniquement dans src/lib/supabase/admin.ts (Server Actions/Route Handlers).
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth (§3.1, §11.2) — utilisées par `supabase/config.toml` en local
# (`supabase start`) via substitution `env(...)`. Sur un projet cloud, se
# configurent plutôt dans Dashboard > Authentication > Providers > Google.
# Console : https://console.cloud.google.com (type "Web application",
# redirect URI `<SUPABASE_URL>/auth/v1/callback`).
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
# Apple — architecture prête (providers/callback/DB/comptes liés), activation
# différée : compte Apple Developer payant requis, indépendamment du temps de
# dev (voir docs/adr/0007-auth-architecture.md). Renseigner ces deux valeurs
# (+ activer `[auth.external.apple]` dans supabase/config.toml, ou le
# provider Apple du dashboard cloud) fait apparaître automatiquement le
# bouton "Continuer avec Apple" — voir
# src/app/[locale]/(auth)/oauth-providers.ts.
SUPABASE_AUTH_EXTERNAL_APPLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=

# ------------------------------------------------------------------------------
# Cloudflare R2 — stockage audio/artwork, compatible S3, sans frais d'egress
# (§6.1, §11.4). Créer un bucket sur le dashboard Cloudflare > R2.
#
# Upload multipart résumable (Sprint 5, voir docs/adr/0009-distribution-module.md) :
# le bucket doit aussi autoriser PUT en CORS pour l'origine du site et
# exposer l'en-tête ETag (Access-Control-Expose-Headers: ETag), sans quoi
# le navigateur ne peut pas lire l'ETag renvoyé par R2 pour CompleteMultipartUpload.
# Exemple de règle CORS (dashboard Cloudflare > R2 > bucket > Settings > CORS Policy) :
#   { "AllowedOrigins": ["https://ton-domaine"], "AllowedMethods": ["PUT"],
#     "AllowedHeaders": ["*"], "ExposeHeaders": ["ETag"] }
# ------------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=sterkte-records-media
# Domaine public (ou CDN custom) servant les fichiers rendus publics (artworks).
R2_PUBLIC_URL=

# ------------------------------------------------------------------------------
# Stripe — abonnements & add-ons pour les marchés internationaux (§11.5)
# Dashboard : https://dashboard.stripe.com/apikeys
# ------------------------------------------------------------------------------
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Secret de vérification de signature du endpoint webhook Stripe.
STRIPE_WEBHOOK_SECRET=

# ------------------------------------------------------------------------------
# Flutterwave — cartes + Mobile Money Afrique (M-Pesa, Airtel, Orange, MTN)
# PSP par défaut pour la RDC (Stripe indisponible localement, §11.5).
# Dashboard : https://dashboard.flutterwave.com/settings/apis
# ------------------------------------------------------------------------------
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_SECRET_HASH=

# ------------------------------------------------------------------------------
# Paystack — cartes + Mobile Money Afrique (alternative/complément Flutterwave)
# Dashboard : https://dashboard.paystack.com/#/settings/developer
# ------------------------------------------------------------------------------
PAYSTACK_SECRET_KEY=

# ------------------------------------------------------------------------------
# PayPal — paiement secondaire [V1]
# ------------------------------------------------------------------------------
PAYPAL_CLIENT_SECRET=

# ------------------------------------------------------------------------------
# Resend — emails transactionnels (§14). Dashboard : https://resend.com/api-keys
# Nécessite un domaine d'expédition vérifié dans Resend avant tout envoi réel.
# ------------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=Sterkte Records <no-reply@sterkterecords.com>

# ------------------------------------------------------------------------------
# Supabase Auth Hook "Send Email" (§14) — remplace le template email par
# défaut de Supabase (vérification, réinitialisation, alertes sécurité) par
# nos gabarits React Email/Resend. Secret affiché lors de la création du hook
# dans Authentication > Hooks du dashboard Supabase (à créer une fois un
# projet réel existe — voir docs/adr/0011-emails-transactionnels.md).
# ------------------------------------------------------------------------------
SUPABASE_AUTH_SEND_EMAIL_HOOK_SECRET=

# ------------------------------------------------------------------------------
# LabelGrid — rail de distribution DSP (§13.1). Onboarding en cours côté
# Sterkte Records : ces valeurs seront fournies par LabelGrid à l'intégration.
# En attendant, src/lib/labelgrid utilise un adaptateur mock (voir le module).
# ------------------------------------------------------------------------------
LABELGRID_API_BASE_URL=
LABELGRID_API_KEY=
LABELGRID_WEBHOOK_SECRET=

# ------------------------------------------------------------------------------
# WhatsApp Business Cloud API (Meta) — notifications push [V1] (§6.1, §14)
# Meta for Developers > ton app > WhatsApp > API Setup.
# ------------------------------------------------------------------------------
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# ------------------------------------------------------------------------------
# Documenso — e-signature des contrats [V1] (§11.11)
# Auto-hébergé ou https://app.documenso.com — voir docs/services/documenso.md
# ------------------------------------------------------------------------------
DOCUMENSO_API_KEY=
DOCUMENSO_BASE_URL=

# ------------------------------------------------------------------------------
# Sentry — monitoring d'erreurs (§6.1, §25)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
# Token + org/project utilisés uniquement en CI/CD pour uploader les sourcemaps.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ------------------------------------------------------------------------------
# PostHog — analytics produit (§6.1, §25)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
POSTHOG_API_KEY=
